<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.miracosta.cs112.controllers.HomeController">
   <children>
      <Label text="MCC Login" />
      <TextField fx:id="usernameField" promptText="Enter Username" />
      <PasswordField fx:id="passwordField" promptText="Password" />
      <Button fx:id="LoginEnabler" onAction="#LoginEnabler" text="Login" />
      <Label fx:id="messageLabel" textFill="red" />
   </children>
</VBox>
